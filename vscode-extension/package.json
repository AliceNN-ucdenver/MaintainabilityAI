{
  "name": "maintainabilityai",
  "displayName": "MaintainabilityAI",
  "description": "Security-first RCTRO issue creation for AI-assisted feature development",
  "version": "0.1.136",
  "publisher": "chiefarcheologist",
  "license": "MIT",
  "preview": true,
  "homepage": "https://maintainability.ai",
  "bugs": {
    "url": "https://github.com/AliceNN-ucdenver/MaintainabilityAI/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AliceNN-ucdenver/MaintainabilityAI"
  },
  "engines": {
    "vscode": "^1.97.0"
  },
  "categories": [
    "Other"
  ],
  "galleryBanner": {
    "color": "#0f172a",
    "theme": "dark"
  },
  "keywords": [
    "security",
    "owasp",
    "ai",
    "github-issues",
    "sdlc"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "icon": "assets/icon.png",
  "contributes": {
    "commands": [
      {
        "command": "maintainabilityai.scaffoldRepo",
        "title": "Scaffold SDLC Structure",
        "category": "MaintainabilityAI",
        "icon": {
          "light": "assets/cheshire-light.svg",
          "dark": "assets/cheshire-dark.svg"
        }
      },
      {
        "command": "maintainabilityai.createIssue",
        "title": "Issue Management",
        "category": "MaintainabilityAI",
        "icon": {
          "light": "assets/cheshire-light.svg",
          "dark": "assets/cheshire-dark.svg"
        }
      },
      {
        "command": "maintainabilityai.browsePromptPacks",
        "title": "Prompt Packs",
        "category": "MaintainabilityAI"
      },
      {
        "command": "maintainabilityai.configureSecrets",
        "title": "Repository Secrets",
        "category": "MaintainabilityAI"
      },
      {
        "command": "maintainabilityai.openScorecard",
        "title": "Security Scorecard",
        "category": "MaintainabilityAI"
      },
      {
        "command": "maintainabilityai.lookingGlass",
        "title": "Looking Glass",
        "category": "MaintainabilityAI",
        "icon": {
          "light": "assets/cheshire-light.svg",
          "dark": "assets/cheshire-dark.svg"
        }
      },
      {
        "command": "maintainabilityai.oraculum",
        "title": "Oraculum — Architecture Review",
        "category": "MaintainabilityAI"
      },
      {
        "command": "maintainabilityai.bugReport",
        "title": "Report a Bug",
        "category": "MaintainabilityAI",
        "icon": "$(bug)"
      },
      {
        "command": "maintainabilityai.newResearch",
        "title": "New Research / PRD Run",
        "category": "MaintainabilityAI",
        "icon": "$(search)"
      },
      {
        "command": "maintainabilityai.activeRuns",
        "title": "Active Research / PRD Runs",
        "category": "MaintainabilityAI",
        "icon": "$(pulse)"
      },
      {
        "command": "maintainabilityai.researchLibrary",
        "title": "Research Library",
        "category": "MaintainabilityAI",
        "icon": "$(library)"
      },
      {
        "command": "maintainabilityai.createResearchRequest",
        "title": "Create Research Request",
        "category": "MaintainabilityAI",
        "icon": "$(comment-discussion)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "maintainabilityai",
          "title": "MaintainabilityAI",
          "icon": "assets/cheshire-activity-dark.svg"
        }
      ]
    },
    "views": {
      "maintainabilityai": [
        {
          "id": "maintainabilityai.governance",
          "name": "Looking Glass",
          "type": "tree"
        },
        {
          "id": "maintainabilityai.actions",
          "name": "The Cheshire Cat",
          "type": "tree"
        }
      ]
    },
    "menus": {
      "editor/title": [
        {
          "command": "maintainabilityai.createIssue",
          "group": "navigation",
          "when": "editorFocus"
        }
      ],
      "commandPalette": [
        {
          "command": "maintainabilityai.scaffoldRepo"
        },
        {
          "command": "maintainabilityai.createIssue"
        },
        {
          "command": "maintainabilityai.browsePromptPacks"
        },
        {
          "command": "maintainabilityai.configureSecrets"
        },
        {
          "command": "maintainabilityai.openScorecard"
        },
        {
          "command": "maintainabilityai.lookingGlass"
        },
        {
          "command": "maintainabilityai.oraculum"
        },
        {
          "command": "maintainabilityai.bugReport"
        },
        {
          "command": "maintainabilityai.newResearch"
        },
        {
          "command": "maintainabilityai.activeRuns"
        },
        {
          "command": "maintainabilityai.researchLibrary"
        },
        {
          "command": "maintainabilityai.createResearchRequest"
        }
      ]
    },
    "configuration": {
      "title": "MaintainabilityAI",
      "properties": {
        "maintainabilityai.llm.provider": {
          "type": "string",
          "enum": [
            "vscode-lm",
            "claude",
            "openai"
          ],
          "default": "vscode-lm",
          "description": "LLM provider for RCTRO prompt generation"
        },
        "maintainabilityai.llm.claudeApiKey": {
          "type": "string",
          "default": "",
          "description": "Anthropic API key (required if provider is 'claude')"
        },
        "maintainabilityai.llm.openaiApiKey": {
          "type": "string",
          "default": "",
          "description": "OpenAI API key (required if provider is 'openai')"
        },
        "maintainabilityai.llm.tavilyApiKey": {
          "type": "string",
          "default": "",
          "description": "Tavily API key (used by the Archeologist research agent for web search). Get one at https://tavily.com/"
        },
        "maintainabilityai.llm.usptoApiKey": {
          "type": "string",
          "default": "",
          "description": "USPTO API key (optional — adds patent coverage to the Archeologist run via the USPTO Open Data Portal at api.uspto.gov/api/v1/patent/applications/search; pipeline degrades gracefully when absent). Request a key at https://data.uspto.gov/apis/getting-started"
        },
        "maintainabilityai.governance.meshToken": {
          "type": "string",
          "default": "",
          "description": "Fine-grained GitHub PAT (GOVERNANCE_MESH_TOKEN). Scopes on every linked code repo: Metadata=read (auto), Issues=read+write (so notify-code-repos.yml on the mesh can open + update PRD landing-issues), Contents=read (lets the workflow cross-reference code-repo files in the issue body). Cannot modify code or trigger workflows. Lives on the mesh repo only. Use Looking Glass → Settings → Research → Create to mint a correctly-scoped token."
        },
        "maintainabilityai.research.llmProvider": {
          "type": "string",
          "enum": [
            "github-models",
            "anthropic",
            "openai"
          ],
          "default": "github-models",
          "description": "Default LLM provider for the Archeologist and PRD agents. `github-models` routes through GitHub Models / Copilot using the workflow GITHUB_TOKEN (no separate API key needed). Per-run override available."
        },
        "maintainabilityai.research.guardrails": {
          "type": "string",
          "enum": [
            "strict",
            "default",
            "lenient"
          ],
          "default": "default",
          "description": "Guardrail mode applied to pre-call and post-call LLM checks in the research/PRD pipelines."
        },
        "maintainabilityai.research.grounding": {
          "type": "string",
          "enum": [
            "strict",
            "default",
            "lenient"
          ],
          "default": "default",
          "description": "PRD grounding mode. Strict = block on any below-threshold expert score; lenient = warn only."
        },
        "maintainabilityai.research.groundingThreshold": {
          "type": "number",
          "minimum": 0.5,
          "maximum": 1,
          "default": 0.85,
          "description": "Minimum grounding score (0.5-1.0) required to publish a PRD without re-iterating."
        },
        "maintainabilityai.research.maxIterations": {
          "type": "number",
          "minimum": 1,
          "maximum": 5,
          "default": 3,
          "description": "Maximum PRD refinement loop iterations before the convergence guard fires."
        },
        "maintainabilityai.research.costCapTokens": {
          "type": "number",
          "minimum": 10000,
          "default": 200000,
          "description": "Default per-run token budget for the research and PRD pipelines (warn before exceeding)."
        },
        "maintainabilityai.llm.model": {
          "type": "string",
          "default": "",
          "description": "Model override (e.g., claude-sonnet-4-5-20250929, gpt-4o)"
        },
        "maintainabilityai.llm.preferredFamily": {
          "type": "string",
          "default": "gpt-4o",
          "description": "Preferred VS Code Language Model family for LLM-powered features (threat models, org scanning, policy generation, top findings)"
        },
        "maintainabilityai.mesh.path": {
          "type": "string",
          "default": "",
          "description": "Path to the Initiative Mesh directory (local clone of your governance mesh monorepo)"
        },
        "maintainabilityai.github.defaultLabels": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "maintainabilityai",
            "rctro-feature"
          ],
          "description": "Default labels applied to every created issue"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "lint": "eslint src --ext ts,tsx",
    "typecheck": "npm run typecheck:extension && npm run typecheck:webview",
    "typecheck:extension": "node --max-old-space-size=8192 ./node_modules/typescript/bin/tsc --noEmit --pretty false",
    "typecheck:webview": "node --max-old-space-size=8192 ./node_modules/typescript/bin/tsc --project tsconfig.webview.json --pretty false",
    "pretest": "npm run build",
    "test": "vitest run",
    "fitness": "vitest run src/mcp/__tests__/architecture-fitness.test.ts",
    "knip": "knip --no-progress",
    "audit": "npm audit --audit-level=high",
    "package:check": "node scripts/check-package.mjs",
    "quality": "npm run lint && npm run typecheck && npm run fitness && npm test && npm run knip && npm run audit && npm run build && npm run package:check",
    "package": "vsce package",
    "prepare-npm": "node esbuild.js --production && mkdir -p ../packages/redqueen-mcp/dist && cp dist/mcp-server.js ../packages/redqueen-mcp/dist/"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/vscode": "^1.97.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.28.0",
    "eslint": "^8.57.0",
    "knip": "^6.14.1",
    "typescript": "^5.5.0",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@octokit/rest": "^21.0.0",
    "@xyflow/react": "^12.10.1",
    "elkjs": "^0.9.3",
    "html-to-image": "^1.11.13",
    "mermaid": "^11.12.3",
    "openai": "^4.68.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "yaml": "^2.9.0",
    "zod": "^3.25.76"
  }
}
